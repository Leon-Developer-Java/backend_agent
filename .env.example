# DeepSeek（OpenAI 兼容接口）配置 —— 复制本文件为 .env 并填写真实值
# 可用模型：deepseek-v4-pro（推理模型，质量高）/ deepseek-v4-flash（更快）

DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# 推理(thinking)开关：enabled/disabled。v4-pro 建议 enabled；用 flash 提速可设 disabled。
DEEPSEEK_THINKING=enabled
DEEPSEEK_REASONING_EFFORT=high

# 生成图片对外可访问的基址（前端通过该地址加载 PNG），默认与后端同址
PUBLIC_BASE_URL=http://127.0.0.1:8004
